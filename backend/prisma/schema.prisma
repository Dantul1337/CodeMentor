generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Course {
  id          Int     @id @default(autoincrement())
  title       String
  description String
  duration    String
  price       String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Application {
  id        Int      @id @default(autoincrement())

  name      String
  email     String
  phone     String

  createdAt DateTime @default(now())
}